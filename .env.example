# Vercel env vars required by /api/leads.
# AIRTABLE_BASE_ID and AIRTABLE_TABLE_NAME are already set on the ns-leads
# Vercel project. AIRTABLE_PAT was stored as Sensitive on nutra-portal and
# cannot be pulled out via CLI, so it must be added once manually:
#
#   echo "<your-pat>" | vercel env add AIRTABLE_PAT production --yes
#
# After adding, redeploy: `vercel deploy --prod` (or push to GitHub).

AIRTABLE_PAT=""
AIRTABLE_BASE_ID="appabLn8sA9YObZ20"
AIRTABLE_TABLE_NAME="Brands"
